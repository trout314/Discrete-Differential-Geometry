# Compiled Object files
*.o
*.obj

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.a
*.lib

# Executables
*.exe
discrete-differential-geometry
discrete-differential-geometry-test-application
discrete-differential-geometry-test-library
/discrete_differential_geometry
manifold_sampler
__pycache__/
*.pyc
.venv/

#unittest coverage files
*.lst

# Meson
builddir/
builddir-release/

# data files created by unittests
data/manifold_sampler_unittest_save.dat
data/simplicial_complex_unittest_save.dat

#data files
*.dat
*.mfd
*.edge_graph
data/seed_gen/

# ...but the standard_triangulations/ library (canonical named triangulations,
# e.g. the 600-cell) IS version-controlled despite the *.mfd rule above.
!standard_triangulations/
!standard_triangulations/*.mfd

#jupyter notebook checkpoints
*checkpoints
*checkpoint.ipynb

# Generated seed triangulations
seeds/

# Experiment output directories (large; not version-controlled).
# Unit-test fixtures already committed under data/ stay tracked (gitignore does
# not untrack); add a new fixture under data/ with `git add -f <path>`.
/data/
/seeds_*/

# Claude Code local memory store
memory/

# D build artifacts
bin/
dub.selections.json

# Stale generated param tables (regenerate via legacy/generate_seed_params.py)
tools/*.json

# Compiled note PDFs (sources .tex are tracked; rebuild with tectonic)
notes/*.pdf

# Analysis output JSONs/figures (like data/, not version-controlled)
/out/

# LaTeX build artifacts
notes/*.aux
notes/*.log
notes/*.out
notes/*.synctex.gz
notes/*.toc
